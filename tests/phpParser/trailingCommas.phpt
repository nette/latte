<?php declare(strict_types=1);

// PHP 7.3 trailing comma additions

use Tester\Assert;

require __DIR__ . '/../bootstrap.php';

$test = <<<'XX'
	foo($a, $b, ),
	$foo->bar($a, $b, ),
	Foo::bar($a, $b, ),
	new Foo($a, $b, ),
	abcde($a, $b, ),
	isset($a, $b, ),
	XX;

$node = parseCode($test);

Assert::same(
	loadContent(__FILE__, __COMPILER_HALT_OFFSET__),
	exportNode($node),
);

__halt_compiler();
